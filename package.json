{
  "name": "telegram-mcp",
  "version": "0.1.0",
  "description": "Read-only Model Context Protocol server for searching and reading Telegram via a user MTProto session.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VanDalkvist/telegram-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/VanDalkvist/telegram-mcp/issues"
  },
  "homepage": "https://github.com/VanDalkvist/telegram-mcp#readme",
  "bin": {
    "telegram-mcp": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "tools",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "telegram",
    "mtproto",
    "gramjs"
  ],
  "scripts": {
    "auth": "tsx src/cli/index.ts auth",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "smoke:live": "npm run build && node tools/live-smoke.mjs",
    "stickers:add": "npm run build && node tools/add-stickers-to-set.mjs",
    "stickers:create": "npm run build && node tools/create-sticker-set.mjs",
    "start": "tsx src/cli/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "big-integer": "^1.6.52",
    "dotenv": "17.2.3",
    "telegram": "2.26.22",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
